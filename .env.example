APP_NAME="SilgoDev Outreach"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Madrid
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Mayor que el timeout del worker para que un envío largo no se re-despache en paralelo.
DB_QUEUE_RETRY_AFTER=3700

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Correo LOCAL (Mailpit vía docker compose) — captura en http://localhost:8025
# Descomenta este bloque y comenta el de Hostinger para probar sin SMTP real.
# -----------------------------------------------------------------------------
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SCHEME=
# MAIL_FROM_ADDRESS="contacto@onez.es"
# MAIL_FROM_NAME="Camilo Silva Gómez"

# -----------------------------------------------------------------------------
# Correo PRODUCCIÓN (Hostinger SMTP) — deliverability real
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=contacto@onez.es
MAIL_PASSWORD=
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS="contacto@onez.es"
MAIL_FROM_NAME="Camilo Silva Gómez"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OUTREACH_OVERPASS_AREA=Madrid
OUTREACH_MAX_DAILY=25
OUTREACH_LEGAL_NAME="Camilo Silva Gómez"
OUTREACH_LEGAL_ADDRESS="Madrid, España"
OUTREACH_UNSUBSCRIBE_EMAIL=contacto@onez.es
OUTREACH_UNSUBSCRIBE_URL=

# IMAP (lectura de rebotes / BAJA / respuestas) — no usar servicios de pago
IMAP_DEFAULT_ACCOUNT=default
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_PROTOCOL=imap
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=
IMAP_PASSWORD=
# IMAP_AUTHENTICATION=  # dejar vacío salvo oauth
IMAP_FOLDER=INBOX
